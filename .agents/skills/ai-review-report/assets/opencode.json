{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "gemini": {
      "npm": "@ai-sdk/google",
      "name": "Gemini",
      "options": {
        "apiKey": "{env:OPENCODE_GEMINI_API_KEY}"
      },
      "models": {
        "gemini-3.1-pro-preview":  { "name": "Gemini 3.1 Pro (preview)" },
        "gemini-2.5-pro":          { "name": "Gemini 2.5 Pro" },
        "gemini-3-flash-preview":  { "name": "Gemini 3 Flash (preview)" },
        "gemini-2.5-flash":        { "name": "Gemini 2.5 Flash" }
      }
    },
    "github-copilot": {
      "npm": "@ai-sdk/github-copilot",
      "name": "GitHub Copilot",
      "options": {
        "apiKey": "{env:OPENCODE_COPILOT_API_KEY}"
      },
      "models": {
        "gpt-5.5": { "name": "GPT-5.5" },
        "gpt-5.4": { "name": "GPT-5.4" },
        "gpt-5.4-mini": { "name": "GPT-5.4 mini" }
      }
    },
    "openai": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI",
      "options": {
        "apiKey": "{env:OPENCODE_OPENAI_API_KEY}"
      },
      "models": {
        "gpt-5.5": { "name": "GPT-5.5" },
        "gpt-5.4": { "name": "GPT-5.4" },
        "gpt-5.4-mini": { "name": "GPT-5.4 mini" }
      }
    },
    "anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Anthropic",
      "options": {
        "baseURL": "https://api.anthropic.com",
        "apiKey": "{env:OPENCODE_ANTHROPIC_API_KEY}"
      },
      "models": {
        "claude-opus-4-8":   { "name": "Claude Opus 4.8" },
        "claude-sonnet-4-6": { "name": "Claude Sonnet 4.6" },
        "claude-haiku-4-5":  { "name": "Claude Haiku 4.5" }
      }
    },
    "go-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go (OpenAI-compatible)",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "{env:OPENCODE_GO_OPENAI_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": { "name": "DeepSeek V4 Flash" },
        "deepseek-v4-pro":   { "name": "DeepSeek V4 Pro" },
        "glm-5.1":           { "name": "GLM-5.1" }
      }
    },
    "go-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "OpenCode Go (Anthropic-compatible)",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "{env:OPENCODE_GO_ANTHROPIC_API_KEY}"
      },
      "models": {
        "minimax-m3":   { "name": "MiniMax M3" },
        "minimax-m2.7": { "name": "MiniMax M2.7" },
        "qwen3.7-plus": { "name": "Qwen3.7 Plus" },
        "qwen3.6-pro":  { "name": "Qwen3.6 Pro" }
      }
    },
    "openrouter": {
      "npm": "@openrouter/ai-sdk-provider",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENCODE_OPENROUTER_API_KEY}"
      },
      "models": {
        "deepseek/deepseek-v4-pro":          { "name": "DeepSeek V4 Pro" },
        "deepseek/deepseek-v4-flash":        { "name": "DeepSeek V4 Flash" },
        "deepseek/deepseek-v3.2":            { "name": "DeepSeek V3.2" },
        "qwen/qwen3.7-plus":                 { "name": "Qwen3.7 Plus" },
        "qwen/qwen3.7-max":                  { "name": "Qwen3.7 Max" },
        "qwen/qwen3.6-max-preview":          { "name": "Qwen3.6 Max (preview)" },
        "z-ai/glm-5.1":                      { "name": "GLM-5.1" },
        "minimax/minimax-m3":                { "name": "MiniMax M3" },
        "minimax/minimax-m2.7":              { "name": "MiniMax M2.7" },
        "xiaomi/mimo-v2.5":                  { "name": "MiMo v2.5" },
        "tencent/hy3-preview":               { "name": "Hunyuan 3 (preview)" },
        "stepfun/step-3.7-flash":            { "name": "Step 3.7 Flash" },
        "nvidia/nemotron-3-ultra-550b-a55b": { "name": "Nemotron 3 Ultra" }
      }
    }
  },
  "share": "disabled",
  "permission": {
    "external_directory": "allow"
  },
  "agent": {
    "analyse": {
      "mode": "primary",
      "description": "Edit-only autonomous low/medium review-fix agent (LADR-042): no skill/task/bash/web access. The workflow supplies only gate-authored medium/low findings and performs git operations itself.",
      "tools": {
        "skill": false,
        "task": false,
        "edit": true,
        "bash": false,
        "webfetch": false,
        "websearch": false
      },
      "permission": {
        "skill": "deny",
        "task": "deny",
        "edit": "allow",
        "bash": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "external_directory": "allow"
      }
    },
    "review": {
      "mode": "primary",
      "description": "Locked-down PR-review agent (LADR-029): no skill/task/edit/bash; read + web (fetch/search) enabled. Disabling skill/task stops the review model self-activating this repo's own ai-review-report skill when a chunk under review contains the gate's workflow/skill files (the empty-output / silent-failure mode); bash is denied so a prompt-injected diff cannot run arbitrary commands on the runner, while webfetch/websearch stay on so the model can verify references during review.",
      "tools": {
        "skill": false,
        "task": false,
        "edit": false,
        "bash": false,
        "webfetch": true,
        "websearch": true
      },
      "permission": {
        "skill": "deny",
        "task": "deny",
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "external_directory": "allow"
      }
    }
  }
}
