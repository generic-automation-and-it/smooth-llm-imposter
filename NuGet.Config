<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Custom / private feed — uncomment and set the value to enable.
    <add key="custom" value="https://your-feed/index.json" protocolVersion="3" />
    -->
  </packageSources>
  <!--
  Credentials for the custom feed (or supply via env / CI secrets):
  <packageSourceCredentials>
    <custom>
      <add key="Username" value="%NUGET_CUSTOM_USER%" />
      <add key="ClearTextPassword" value="%NUGET_CUSTOM_TOKEN%" />
    </custom>
  </packageSourceCredentials>
  -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <!-- Route specific package prefixes to the custom feed.
    <packageSource key="custom">
      <package pattern="YourCompany.*" />
    </packageSource>
    -->
  </packageSourceMapping>
</configuration>
