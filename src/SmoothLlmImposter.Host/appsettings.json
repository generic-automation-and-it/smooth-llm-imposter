{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "SmoothLlmImposter": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "Imposter": {
    "Providers": {
      "anthropic-default": {
        "Dialect": "anthropic",
        "BaseUrl": "https://api.anthropic.com",
        "IsDefault": true
      },
      "openai-default": {
        "Dialect": "openai",
        "BaseUrl": "https://chatgpt.com/backend-api/codex",
        "IsDefault": true
      },
      "opencode-go-anthropic": {
        "Dialect": "anthropic",
        "BaseUrl": "https://opencode.ai/zen/go",
        "SessionForwarding": "opencode-go",
        "Models": []
      },
      "opencode-go-openai": {
        "Dialect": "openai",
        "BaseUrl": "https://opencode.ai/zen/go",
        "SessionForwarding": "opencode-go",
        "Secret": "",
        "AuthScheme": "Bearer",
        "OpenAiUpstreamApi": "chat_completions",
        "Models": []
      }
    }
  }
}
